#!/usr/bin/env bash
# PostCompact hook: emit spec-tree re-anchoring directives after compaction.
#
# The harness injects the compact summary into the ongoing session's context.
# This hook runs in that same session immediately after compaction and emits
# skill invocation directives via stdout, which the harness also injects into
# the session. No file is written — everything stays in-session.
#
# Emits to stdout (injected into Claude's context by the harness):
#   <SPEC-TREE_RESUMED active-node="spx/..."/>  when a node is recorded
#   <SPEC-TREE_RESUMED/>                        when no spec-tree node was active
#   /spec-tree:understanding                    when <SPEC_TREE_FOUNDATION> was active
#   /spec-tree:contextualizing spx/...          when foundation active and node known
#
# Reads (from PostCompact JSON payload on stdin):
#   .compact_summary  The full compaction output produced by the harness.

set -euo pipefail

json_string() {
	local filter="$1"
	jq -er "$filter | strings | select(length > 0)"
}

extract_active_node() {
	# Return the first line starting with "spx/" that follows the
	# "### Active spec-tree node" header. Returns empty string when absent.
	awk '
		/^### Active spec-tree node/ { found=1; next }
		found && /^spx\// { print; exit }
		found && /^### / { exit }
	'
}

main() {
	local input
	local summary
	local has_foundation=false
	local active_node

	input="$(cat)"

	summary="$(json_string '.compact_summary' <<<"$input")" || {
		# No summary in payload — nothing to emit.
		exit 0
	}

	# Anchor to start of line to avoid false positives from code blocks.
	if printf '%s\n' "$summary" | grep -qE '^<SPEC_TREE_FOUNDATION>'; then
		has_foundation=true
	fi

	active_node="$(printf '%s\n' "$summary" | extract_active_node)"

	if [[ -n "$active_node" ]]; then
		printf '<SPEC-TREE_RESUMED active-node="%s"/>\n' "$active_node"
	else
		printf '<SPEC-TREE_RESUMED/>\n'
	fi

	if [[ "$has_foundation" == true ]]; then
		printf '/spec-tree:understanding\n'
		if [[ -n "$active_node" ]]; then
			printf '/spec-tree:contextualizing %s\n' "$active_node"
		fi
	fi
}

main "$@"
