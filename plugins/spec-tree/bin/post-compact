#!/usr/bin/env bash
# PostCompact hook: persist the compact summary so the next session can load it.
#
# Writes:
#   .spx/compact-<session_id>.md  Session-scoped compact summary.
#
# Reads (from PostCompact JSON payload on stdin):
#   .compact_summary  The full compaction output.
#   .session_id       Session identifier (used in the output filename).
#   .cwd              Fallback project root when CLAUDE_PROJECT_DIR is unset.
#
# Reads (from environment):
#   CLAUDE_PROJECT_DIR  Canonical project root.

set -euo pipefail

warn() {
	# Do not write to stdout from a hook: stdout is injected into Claude's context.
	printf 'post-compact: %s\n' "$*" >&2
}

json_string() {
	local filter="$1"
	jq -er "$filter | strings | select(length > 0)"
}

main() {
	local input
	local summary
	local session_id
	local project_dir
	local out_file
	local tmp_file

	input="$(cat)"

	summary="$(json_string '.compact_summary' <<<"$input")" || {
		# No summary in payload — nothing to persist.
		exit 0
	}

	session_id="$(json_string '.session_id' <<<"$input")" || {
		warn "missing .session_id in payload; cannot write session-scoped compact file"
		exit 0
	}

	# Prefer the env var exported by session-start over the payload's .cwd,
	# which may not be the project root on all runtimes.
	project_dir="${CLAUDE_PROJECT_DIR:-}"
	if [[ -z "$project_dir" ]]; then
		project_dir="$(json_string '.cwd' <<<"$input" || true)"
		if [[ -n "$project_dir" ]]; then
			warn "CLAUDE_PROJECT_DIR is unset; falling back to .cwd, which may not be the project root"
		fi
	fi

	if [[ -z "$project_dir" ]]; then
		warn "project directory unavailable; cannot persist compact summary"
		exit 0
	fi

	if [[ ! -d "$project_dir" ]]; then
		warn "project directory does not exist: $project_dir"
		exit 0
	fi

	out_file="$project_dir/.spx/compact-${session_id}.md"
	tmp_file="${out_file}.tmp.$$"

	mkdir -p "$(dirname "$out_file")"
	printf '%s\n' "$summary" >"$tmp_file"
	mv "$tmp_file" "$out_file"
}

main "$@"
