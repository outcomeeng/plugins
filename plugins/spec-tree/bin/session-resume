#!/usr/bin/env bash
# SessionStart hook: atomically claim and inject any pending compact summary.
#
# When .spx/sessions/tmp/compact-<old_session_id>.md is present, this script:
#   1. Claims it atomically (mv to .processing-<new_session_id>)
#   2. Writes the claimed path to .spx/sessions/tmp/compact-active (for compact-done cleanup)
#   3. Injects the content into Claude's context via stdout with a preamble
#      directing the receiving agent to invoke /handing-off then compact-done.
#
# Reads (from SessionStart JSON payload on stdin):
#   .session_id   New session identifier (used in the claimed filename).
#
# Reads (from environment):
#   CLAUDE_PROJECT_DIR   Canonical project root.

set -euo pipefail

warn() {
	# Intentional: do not write to stdout except for context injection below.
	printf 'session-resume: %s\n' "$*" >&2
}

json_string() {
	local filter="$1"
	jq -er "$filter | strings | select(length > 0)"
}

main() {
	local input
	local new_session_id
	local project_dir
	local compact_done
	local compact_md
	local old_id
	local claimed

	input="$(cat)"

	new_session_id="$(json_string '.session_id' <<<"$input")" || {
		warn "missing .session_id in payload; cannot claim compact summary"
		exit 0
	}

	project_dir="${CLAUDE_PROJECT_DIR:-}"
	if [[ -z "$project_dir" ]]; then
		project_dir="$(json_string '.cwd' <<<"$input" || true)"
		if [[ -n "$project_dir" ]]; then
			warn "CLAUDE_PROJECT_DIR is unset; falling back to .cwd, which may not be the project root"
		fi
	fi

	if [[ -z "$project_dir" ]]; then
		warn "CLAUDE_PROJECT_DIR is unset; cannot locate compact summaries"
		exit 0
	fi

	# Derive compact-done path from this script's resolved location.
	compact_done="$(cd "$(dirname "$0")" && pwd)/compact-done"

	# Scan for unclaimed compact summaries. The glob compact-*.md naturally excludes
	# claimed files — they have no .md extension after the atomic rename.
	for compact_md in "$project_dir"/.spx/sessions/tmp/compact-*.md; do
		[[ -f "$compact_md" ]] || continue

		old_id="$(basename "$compact_md" .md)"
		old_id="${old_id#compact-}"
		claimed="$project_dir/.spx/sessions/tmp/compact-${old_id}.processing-${new_session_id}"

		# Atomic claim: mv is a single directory-entry rename on the same filesystem.
		# If two sessions start simultaneously, only one mv wins; the other skips.
		mv "$compact_md" "$claimed" 2>/dev/null || continue

		# Write pointer so compact-done knows which file to remove.
		printf '%s\n' "$claimed" >"$project_dir/.spx/sessions/tmp/compact-active"

		# Stdout from a SessionStart hook is injected into Claude's context.
		printf '## Context from previous compaction\n\n'
		printf 'The previous session compacted before explicit closure. The summary\n'
		printf 'below contains the built-in 9-section compaction output; if spec-tree\n'
		printf 'work occurred, sections ### Nodes, ### Lessons, ### Skills,\n'
		printf '### Starting Point, ### Persistence Proposal, and ### Session Scope\n'
		printf 'follow the standard sections.\n\n'
		printf '**Before responding to any user message, invoke `/spec-tree:handing-off` now.**\n'
		printf 'Complete workflows 03–04: present the Persistence Proposal to the user, write\n'
		printf 'approved items, and create a session file via `spx session handoff`. Then run:\n'
		printf '  %s\n\n' "$compact_done"
		printf -- '---\n\n'
		cat "$claimed"

		# Only claim and inject one file per session start.
		break
	done
}

main "$@"
