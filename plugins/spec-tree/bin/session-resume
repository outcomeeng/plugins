#!/usr/bin/env bash
# SessionStart hook: claim any pending compact summary and emit spec-tree
# re-anchoring directives. The harness already injects the compact summary
# into the new session's context; this hook's only job is to emit the skill
# invocations the harness cannot produce.
#
# When .spx/sessions/tmp/compact-<old_session_id>.md is present, this script:
#   1. Claims it atomically (mv to .processing-<new_session_id>)
#   2. Extracts the active node from the ### Active spec-tree node section
#   3. Emits <SPEC-TREE_RESUMED active-node="..."/> (or without attribute)
#   4. Emits /spec-tree:understanding and /spec-tree:contextualizing when
#      <SPEC_TREE_FOUNDATION> was active pre-compact and a node is recorded
#   5. Removes the claimed file
#
# Reads (from SessionStart JSON payload on stdin):
#   .session_id   New session identifier (used in the claimed filename).
#
# Reads (from environment):
#   CLAUDE_PROJECT_DIR   Canonical project root.

set -euo pipefail

warn() {
	# Intentional: do not write to stdout except for directives below.
	printf 'session-resume: %s\n' "$*" >&2
}

json_string() {
	local filter="$1"
	jq -er "$filter | strings | select(length > 0)"
}

extract_active_node() {
	# Return the first line starting with "spx/" that follows the
	# "### Active spec-tree node" header. Returns empty string when absent.
	local file="$1"
	awk '
		/^### Active spec-tree node/ { found=1; next }
		found && /^spx\// { print; exit }
		found && /^### / { exit }
	' "$file"
}

main() {
	local input
	local new_session_id
	local project_dir
	local compact_md
	local old_id
	local claimed

	input="$(cat)"

	new_session_id="$(json_string '.session_id' <<<"$input")" || {
		warn "missing .session_id in payload; cannot claim compact summary"
		exit 0
	}

	project_dir="${CLAUDE_PROJECT_DIR:-}"
	if [[ -z "$project_dir" ]]; then
		project_dir="$(json_string '.cwd' <<<"$input" || true)"
		if [[ -n "$project_dir" ]]; then
			warn "CLAUDE_PROJECT_DIR is unset; falling back to .cwd, which may not be the project root"
		fi
	fi

	if [[ -z "$project_dir" ]]; then
		warn "CLAUDE_PROJECT_DIR is unset; cannot locate compact summaries"
		exit 0
	fi

	# Scan for unclaimed compact summaries. The glob compact-*.md naturally excludes
	# claimed files — they have no .md extension after the atomic rename.
	for compact_md in "$project_dir"/.spx/sessions/tmp/compact-*.md; do
		[[ -f "$compact_md" ]] || continue

		old_id="$(basename "$compact_md" .md)"
		old_id="${old_id#compact-}"
		claimed="$project_dir/.spx/sessions/tmp/compact-${old_id}.processing-${new_session_id}"

		# Atomic claim: mv is a single directory-entry rename on the same filesystem.
		# If two sessions start simultaneously, only one mv wins; the other skips.
		mv "$compact_md" "$claimed" 2>/dev/null || continue

		local has_foundation=false
		if grep -qF '<SPEC_TREE_FOUNDATION>' "$claimed" 2>/dev/null; then
			has_foundation=true
		fi

		local active_node
		active_node="$(extract_active_node "$claimed")"

		# Emit the namespaced resumed marker. The harness has already injected the
		# compact summary prose; this marker signals that spec-tree processed it.
		if [[ -n "$active_node" ]]; then
			printf '<SPEC-TREE_RESUMED active-node="%s"/>\n' "$active_node"
		else
			printf '<SPEC-TREE_RESUMED/>\n'
		fi

		# Emit skill invocations when the foundation was active pre-compact.
		# /understanding reloads the methodology; /contextualizing reloads the node.
		if [[ "$has_foundation" == true ]]; then
			printf '/spec-tree:understanding\n'
			if [[ -n "$active_node" ]]; then
				printf '/spec-tree:contextualizing %s\n' "$active_node"
			fi
		fi

		rm "$claimed"

		# Only claim and process one file per session start.
		break
	done
}

main "$@"
