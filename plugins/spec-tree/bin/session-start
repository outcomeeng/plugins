#!/usr/bin/env bash
# SessionStart hook: export CLAUDE_SESSION_ID so every Bash tool call in this
# conversation sees it. The spec-tree plugin uses this id to scope session
# handoff accumulation under .spx/sessions/$CLAUDE_SESSION_ID/.
#
# The per-runtime directory is created lazily by `spx session pickup` on first
# successful claim. Creating it here unconditionally produced empty directories
# for every conversation that never claimed a session.
set -euo pipefail

INPUT=$(cat)
SESSION_ID=$(echo "$INPUT" | jq -r '.session_id')

# Persist the session ID so every subsequent Bash tool call sees it as
# $CLAUDE_SESSION_ID. This mirrors Codex's $CODEX_THREAD_ID, enabling the CLI
# and skills to locate the agent's own session directory without relying on
# file-system heuristics.
if [[ -n "${CLAUDE_ENV_FILE:-}" ]]; then
  echo "export CLAUDE_SESSION_ID=$SESSION_ID" >> "$CLAUDE_ENV_FILE"
fi
