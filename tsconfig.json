{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@eslint-rules/*": [
        "./plugins/typescript/skills/standardizing-typescript-tests/eslint-rules/*"
      ]
    }
  },
  "include": [
    "spx/**/*.ts",
    "plugins/typescript/skills/standardizing-typescript-tests/eslint-rules/**/*.ts",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    "**/.venv",
    "**/dist"
  ]
}
